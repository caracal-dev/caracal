#!/usr/bin/bash
# Installs Caracal's default Flatpak apps outside the login-critical session
# startup path so fresh installs do not block on network/package operations.

set -oue pipefail

if [ "${EUID:-$(id -u)}" -lt 1000 ]; then
  echo "caracal-flatpak-setup: skipping system user."
  exit 0
fi

CARACAL_CONFIG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/caracal"
mkdir -p "$CARACAL_CONFIG_DIR"
FLATPAK_SETUP_VER=1
FLATPAK_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/flatpak-version"

if [[ -f "$FLATPAK_SETUP_VER_FILE" ]]; then
  STORED_VER=$(cat "$FLATPAK_SETUP_VER_FILE")
  if [[ "$FLATPAK_SETUP_VER" == "$STORED_VER" ]]; then
    echo "caracal-flatpak-setup v$FLATPAK_SETUP_VER already ran."
    exit 0
  fi
fi

flatpak remote-add --user --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true

DEFAULT_FLATPAKS=(
  io.github.kolunmi.Bazaar
  app.zen_browser.zen
  org.tenacityaudio.Tenacity
  com.ranfdev.DistroShelf
  org.kde.haruna
  org.gnome.Decibels
  io.github.b43NnUNF4vidFYFhpqaLWy2ANawtRbMtUXZY9Pf.jumpdf
  org.gnome.Loupe
)

missing_flatpaks=()
for app_id in "${DEFAULT_FLATPAKS[@]}"; do
  if ! flatpak info --user "$app_id" >/dev/null 2>&1; then
    missing_flatpaks+=("$app_id")
  fi
done

if ((${#missing_flatpaks[@]} > 0)); then
  flatpak install --user -y flathub "${missing_flatpaks[@]}"
fi

# Remove any legacy Firefox flatpak (Zen Browser is the default browser).
# Try both user and system scope so rebases away from browser-heavy images
# actually converge on the Caracal default set.
flatpak uninstall --user -y org.mozilla.firefox 2>/dev/null || true
flatpak uninstall --system -y org.mozilla.firefox 2>/dev/null || true

flatpak update --appstream

echo "$FLATPAK_SETUP_VER" >"$FLATPAK_SETUP_VER_FILE"
echo "caracal-flatpak-setup v$FLATPAK_SETUP_VER complete."
