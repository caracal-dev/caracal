#!/usr/bin/env bash

set -euo pipefail

caracal_bg="/usr/share/wallpapers/caracal/caracal-lake.png"
theme_source="/usr/share/sddm/themes/caracal/theme.conf"
theme_override_dir="/var/sddm_themes/themes/caracal"
theme_override="${theme_override_dir}/theme.conf"
user_override="/var/lib/sddm/.local/share/sddm/themes/caracal/theme.conf.user"

patch_theme_file() {
  local source_file="$1"
  local target_file="$2"

  if [[ ! -f "${source_file}" ]]; then
    return 0
  fi

  if grep -q "^background=${caracal_bg}$" "${target_file}" 2>/dev/null; then
    return 0
  fi

  if ! grep -q '^background=/usr/share/backgrounds/default\.jxl$' "${source_file}" \
    && ! grep -q '^background=/usr/share/backgrounds/default\.jxl$' "${target_file}" 2>/dev/null; then
    return 0
  fi

  local tmp
  tmp="$(mktemp)"

  awk -v bg="${caracal_bg}" '
    BEGIN {
      seen_general = 0
      saw_type = 0
      saw_background = 0
    }
    /^\[General\]$/ {
      seen_general = 1
      print
      next
    }
    /^type=/ {
      saw_type = 1
      print "type=image"
      next
    }
    /^background=/ {
      saw_background = 1
      print "background=" bg
      next
    }
    { print }
    END {
      if (!seen_general) {
        print "[General]"
      }
      if (!saw_type) {
        print "type=image"
      }
      if (!saw_background) {
        print "background=" bg
      }
    }
  ' "${source_file}" > "${tmp}"

  install -D -m 0644 "${tmp}" "${target_file}"
  rm -f "${tmp}"
}

# Repair the actual theme.conf via the writable SDDM overlay so a stale lowerdir
# copy from an older deployment stops winning at the greeter.
if [[ -f "${theme_source}" ]]; then
  install -d -m 0755 "${theme_override_dir}"
  patch_theme_file "${theme_source}" "${theme_override}"
fi

# Only rewrite the stock Fedora/KDE user override. Leave genuine user
# customizations from System Settings untouched.
if [[ -f "${user_override}" ]]; then
  tmp="$(mktemp)"
  trap 'rm -f "${tmp}"' EXIT

  if grep -q '^background=/usr/share/backgrounds/default\.jxl$' "${user_override}"; then
    awk -v bg="${caracal_bg}" '
      BEGIN {
        seen_general = 0
        saw_type = 0
        saw_background = 0
      }
      /^\[General\]$/ {
        seen_general = 1
        print
        next
      }
      /^type=/ {
        saw_type = 1
        print "type=image"
        next
      }
      /^background=/ {
        saw_background = 1
        print "background=" bg
        next
      }
      { print }
      END {
        if (!seen_general) {
          print "[General]"
        }
        if (!saw_type) {
          print "type=image"
        }
        if (!saw_background) {
          print "background=" bg
        }
      }
    ' "${user_override}" > "${tmp}"

    install -o sddm -g sddm -m 0644 "${tmp}" "${user_override}"
  fi
fi
