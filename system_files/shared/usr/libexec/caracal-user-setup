#!/usr/bin/bash
# Applies Caracal OS branding and default apps to the current user's config.
# Runs in two phases: a pre-session migration that must finish before Plasma
# starts, plus a post-session phase for wallpaper application that needs a live
# graphical session. Version tracking forces reruns across rebases when needed.

set -oue pipefail

if [ "${EUID:-$(id -u)}" -lt 1000 ]; then
  echo "caracal-user-setup: skipping system user."
  exit 0
fi

CARACAL_CONFIG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/caracal"
mkdir -p "$CARACAL_CONFIG_DIR"
PRE_SESSION_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/pre-session-version"
POST_SESSION_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/post-session-version"
FLATPAK_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/flatpak-version"

WALLPAPER="/usr/share/wallpapers/caracal/caracal-lake.png"
USER_SHELL="$(getent passwd "$(id -un)" | cut -d: -f7)"
ALACRITTY_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/alacritty/alacritty.toml"
USER_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
SOFTWARE_INSTALLER_DESKTOP_SOURCE="/usr/share/applications/caracal-software-installer.desktop"
SYSTEM_KICKOFF_FAVORITES_FILE="/etc/xdg/kactivitymanagerd-statsrc"
USER_KICKOFF_FAVORITES_FILE="$USER_CONFIG_DIR/kactivitymanagerd-statsrc"
USER_PLASMA_APPLETSRC="$USER_CONFIG_DIR/plasma-org.kde.plasma.desktop-appletsrc"
USER_PLASMASHELLRC="$USER_CONFIG_DIR/plasmashellrc"
MODE="${1:-pre-session}"

mkdir -p "$USER_CONFIG_DIR"

launch_default_flatpak_setup() {
  local current_flatpak_ver=""

  if [[ -f "$FLATPAK_SETUP_VER_FILE" ]]; then
    current_flatpak_ver=$(cat "$FLATPAK_SETUP_VER_FILE")
  fi

  if [[ "$DEFAULT_FLATPAK_SETUP_VER" == "$current_flatpak_ver" ]]; then
    return
  fi

  if command -v systemctl &>/dev/null &&
    systemctl --user --quiet is-active caracal-flatpak-setup.service; then
    return
  fi

  # Default Flatpak installs can take time and depend on network availability.
  # Run them outside the login-critical oneshot so Plasma can finish starting.
  if command -v systemd-run &>/dev/null; then
    systemd-run \
      --user \
      --quiet \
      --collect \
      --unit=caracal-flatpak-setup \
      --property=Type=exec \
      /usr/libexec/caracal-flatpak-setup || true
  else
    echo "caracal-user-setup: systemd-run unavailable; skipping async flatpak bootstrap." >&2
  fi
}

migrate_legacy_panel_launcher_id() {
  [[ -f "$USER_PLASMA_APPLETSRC" ]] || return
  sed -i \
    's|applications:Alacritty\.desktop|applications:org.alacritty.Alacritty.desktop|g' \
    "$USER_PLASMA_APPLETSRC"
}

drop_invalid_user_plasma_layout() {
  [[ -f "$USER_PLASMA_APPLETSRC" ]] || return

  # A valid Plasma shell layout contains containment sections. We previously
  # shipped an incomplete appletsrc seed that could leave users with a blank
  # desktop after the next login; drop that malformed user copy so Plasma can
  # regenerate a normal layout.
  if ! grep -qE '^\[Containments\]\[[0-9]+\]' "$USER_PLASMA_APPLETSRC"; then
    rm -f "$USER_PLASMA_APPLETSRC"
  fi
}

drop_user_seeded_kickoff_favorites_if_pristine() {
  [[ -f "$USER_KICKOFF_FAVORITES_FILE" ]] || return
  [[ -f "$SYSTEM_KICKOFF_FAVORITES_FILE" ]] || return

  if cmp -s "$USER_KICKOFF_FAVORITES_FILE" "$SYSTEM_KICKOFF_FAVORITES_FILE"; then
    rm -f "$USER_KICKOFF_FAVORITES_FILE"
  fi
}

set_kickoff_favorites() {
  local appletsrc="$USER_CONFIG_DIR/plasma-org.kde.plasma.desktop-appletsrc"
  [[ -f "$appletsrc" ]] || return

  # Find the Kickoff applet's numeric ID from the appletsrc.
  # Section headers look like: [Containments][N][Applets][M]
  # We track M then check if the next plugin= line is Kickoff.
  local kickoff_id
  kickoff_id=$(awk '
    /^\[Containments\]\[[0-9]+\]\[Applets\]\[[0-9]+\]$/ {
      s = $0
      gsub(/.*\[Applets\]\[/, "", s)
      gsub(/\].*/, "", s)
      last_id = s
    }
    /^plugin=org\.kde\.plasma\.kickoff/ { print last_id; exit }
  ' "$appletsrc")
  [[ -n "$kickoff_id" ]] || return

  local statsrc="$USER_CONFIG_DIR/kactivitymanagerd-statsrc"
  local group="Favorites-org.kde.plasma.kickoff.favorites.instance-${kickoff_id}-global"
  local favorites="ardour9.desktop,org.rncbc.qtractor.desktop,carla.desktop,org.hydrogenmusic.Hydrogen.desktop,org.rncbc.qjackctl.desktop,org.tenacityaudio.Tenacity.desktop,guitarix.desktop,org.pulseaudio.pavucontrol.desktop,preferred://browser,org.kde.dolphin.desktop,systemsettings.desktop"

  local current
  current=$(kreadconfig6 --file "$statsrc" --group "$group" --key ordering 2>/dev/null || true)

  # Replace if empty or if the ordering still contains apps not shipped in this image.
  if [[ -z "$current" ]] || echo "$current" | grep -qE "cardinal\.desktop|musescore|qsynth|yoshimi|sooperlooper"; then
    kwriteconfig6 --file "$statsrc" --group "$group" --key ordering "$favorites"
  fi
}

apply_default_theme_config() {
  kwriteconfig6 \
    --file "$USER_CONFIG_DIR/kdeglobals" \
    --group KDE \
    --key LookAndFeelPackage "org.kde.breezedark.desktop"

  kwriteconfig6 \
    --file "$USER_CONFIG_DIR/kdeglobals" \
    --group General \
    --key ColorScheme "BreezeDark"

  kwriteconfig6 \
    --file "$USER_CONFIG_DIR/plasmarc" \
    --group Theme \
    --key name "breeze-dark"

  kwriteconfig6 \
    --file "$USER_CONFIG_DIR/ksplashrc" \
    --group KSplash \
    --key Theme "org.kde.breezedark.desktop"
}

disable_floating_panels() {
  [[ -f "$USER_PLASMASHELLRC" ]] || return

  awk '
    /^\[PlasmaViews\]\[Panel [0-9]+\]$/ {
      print
      in_panel=1
      next
    }
    /^\[/ {
      in_panel=0
      print
      next
    }
    in_panel && /^floating=/ {
      print "floating=0"
      next
    }
    { print }
  ' "$USER_PLASMASHELLRC" > "${USER_PLASMASHELLRC}.tmp"

  mv "${USER_PLASMASHELLRC}.tmp" "$USER_PLASMASHELLRC"
}

reset_legacy_user_plasma_layout() {
  [[ -f "$USER_PLASMA_APPLETSRC" ]] || return

  # v26 rewrote user appletsrc with Python configparser after Plasma started.
  # That broken rewrite can survive rebases and make plasmashell crash on the
  # next login. If we see the old Caracal panel branding markers on a profile
  # that has not passed the new pre-session migration yet, back it up and let
  # Plasma regenerate a clean layout.
  local needs_reset=0
  if grep -qE '^icon=distributor-logo' "$USER_PLASMA_APPLETSRC"; then
    needs_reset=1
  fi
  if grep -qE '^launchers=applications:app\.zen_browser\.zen\.desktop,applications:org\.alacritty\.Alacritty\.desktop,applications:io\.github\.kolunmi\.Bazaar\.desktop,applications:ardour9\.desktop,preferred://filemanager' "$USER_PLASMA_APPLETSRC"; then
    needs_reset=1
  fi
  (( needs_reset )) || return

  local backup_path="${USER_PLASMA_APPLETSRC}.caracal-v26.bak"
  if [[ ! -f "$backup_path" ]]; then
    cp -a "$USER_PLASMA_APPLETSRC" "$backup_path"
  fi
  rm -f "$USER_PLASMA_APPLETSRC"
}

should_run_versioned_setup() {
  local version_file="$1"
  local desired_version="$2"
  local stored_version=""

  if [[ -f "$version_file" ]]; then
    stored_version=$(cat "$version_file")
  fi

  [[ "$stored_version" != "$desired_version" ]]
}

run_pre_session_setup() {
  apply_default_theme_config
  disable_floating_panels
  drop_invalid_user_plasma_layout
  reset_legacy_user_plasma_layout
  migrate_legacy_panel_launcher_id
  drop_user_seeded_kickoff_favorites_if_pristine
  set_kickoff_favorites

  # -- Lock screen wallpaper --
  kwriteconfig6 \
    --file "$HOME/.config/kscreenlockerrc" \
    --group Greeter --group Wallpaper --group org.kde.image --group General \
    --key Image "$WALLPAPER"

  kwriteconfig6 \
    --file "$HOME/.config/kscreenlockerrc" \
    --group Greeter --group Wallpaper --group org.kde.image --group General \
    --key PreviewImage "$WALLPAPER"

  # -- Desktop shortcuts --
  DESKTOP_DIR="$(xdg-user-dir DESKTOP 2>/dev/null || true)"
  if [[ -z "$DESKTOP_DIR" ]]; then
    DESKTOP_DIR="$HOME/Desktop"
  fi

  if [[ -f "$SOFTWARE_INSTALLER_DESKTOP_SOURCE" ]]; then
    install -d "$DESKTOP_DIR"
    install -m755 "$SOFTWARE_INSTALLER_DESKTOP_SOURCE" \
      "$DESKTOP_DIR/caracal-software-installer.desktop"
  fi

  # -- Alacritty migration --
  if [[ -n "$USER_SHELL" ]] && [[ -f "$ALACRITTY_CONFIG" ]]; then
    sed -i "s|program = \"/usr/libexec/zena-shell\"|program = \"$USER_SHELL\"|" "$ALACRITTY_CONFIG"
  fi

  # Prefer Alacritty for KDE terminal launches in the current user session.
  kwriteconfig6 \
    --file "$USER_CONFIG_DIR/kdeglobals" \
    --group General \
    --key TerminalApplication "org.alacritty.Alacritty.desktop"
}

run_post_session_setup() {
  # plasma-apply-wallpaperimage needs a live Plasma session.
  if command -v plasma-apply-wallpaperimage &>/dev/null; then
    plasma-apply-wallpaperimage "$WALLPAPER" || true
  fi

  # Ensure existing users also resolve browser launches to Zen Browser.
  # These commands often require a running session bus/portal.
  xdg-settings set default-web-browser app.zen_browser.zen.desktop 2>/dev/null || true
  for mime in \
    text/html \
    x-scheme-handler/http \
    x-scheme-handler/https \
    x-scheme-handler/ftp \
    x-scheme-handler/chrome \
    application/xhtml+xml \
    application/x-extension-htm \
    application/x-extension-html \
    application/x-extension-shtml \
    application/x-extension-xhtml \
    application/x-extension-xht; do
    xdg-mime default app.zen_browser.zen.desktop "$mime" 2>/dev/null || true
  done
}

# Bump this when user-config migrations need re-application across rebases.
PRE_SESSION_SETUP_VER=28
POST_SESSION_SETUP_VER=28
DEFAULT_FLATPAK_SETUP_VER=1

launch_default_flatpak_setup

case "$MODE" in
  pre-session)
    if ! should_run_versioned_setup "$PRE_SESSION_SETUP_VER_FILE" "$PRE_SESSION_SETUP_VER"; then
      echo "caracal-user-setup pre-session v$PRE_SESSION_SETUP_VER already ran."
      exit 0
    fi

    run_pre_session_setup
    echo "$PRE_SESSION_SETUP_VER" >"$PRE_SESSION_SETUP_VER_FILE"
    echo "caracal-user-setup pre-session v$PRE_SESSION_SETUP_VER complete."
    ;;
  post-session)
    if ! should_run_versioned_setup "$POST_SESSION_SETUP_VER_FILE" "$POST_SESSION_SETUP_VER"; then
      echo "caracal-user-setup post-session v$POST_SESSION_SETUP_VER already ran."
      exit 0
    fi

    run_post_session_setup
    echo "$POST_SESSION_SETUP_VER" >"$POST_SESSION_SETUP_VER_FILE"
    echo "caracal-user-setup post-session v$POST_SESSION_SETUP_VER complete."
    ;;
  *)
    echo "caracal-user-setup: unknown mode '$MODE'." >&2
    exit 1
    ;;
esac
