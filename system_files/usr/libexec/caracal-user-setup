#!/usr/bin/bash
# Applies Caracal OS branding to the current user's config.
# Runs after the graphical session starts so plasma-apply-wallpaperimage works.
# Uses version tracking so it re-runs whenever the number below is bumped,
# which ensures branding survives a bootc rebase from another image.

set -oue pipefail

if [ "${EUID:-$(id -u)}" -lt 1000 ]; then
  echo "caracal-user-setup: skipping system user."
  exit 0
fi

CARACAL_CONFIG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/caracal"
mkdir -p "$CARACAL_CONFIG_DIR"

# Bump this when branding changes that need re-application across rebases.
USER_SETUP_VER=1
USER_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/version"

if [[ -f "$USER_SETUP_VER_FILE" ]]; then
  STORED_VER=$(cat "$USER_SETUP_VER_FILE")
  if [[ "$USER_SETUP_VER" == "$STORED_VER" ]]; then
    echo "caracal-user-setup v$USER_SETUP_VER already ran. Exiting."
    exit 0
  fi
fi

WALLPAPER="/usr/share/wallpapers/caracal/caracal-lake.png"

# -- Lock screen wallpaper --
# Written directly into the user config so it takes precedence over any stale
# ~/.config/kscreenlockerrc left over from a previous image (e.g. after rebase).
kwriteconfig6 \
  --file "$HOME/.config/kscreenlockerrc" \
  --group Greeter --group Wallpaper --group org.kde.image --group General \
  --key Image "$WALLPAPER"

kwriteconfig6 \
  --file "$HOME/.config/kscreenlockerrc" \
  --group Greeter --group Wallpaper --group org.kde.image --group General \
  --key PreviewImage "$WALLPAPER"

# -- Desktop wallpaper --
# plasma-apply-wallpaperimage talks to plasmashell over D-Bus; the service runs
# After=graphical-session.target so Plasma is already up at this point.
if command -v plasma-apply-wallpaperimage &>/dev/null; then
  plasma-apply-wallpaperimage "$WALLPAPER" || true
fi

echo "$USER_SETUP_VER" > "$USER_SETUP_VER_FILE"
echo "caracal-user-setup v$USER_SETUP_VER complete."
